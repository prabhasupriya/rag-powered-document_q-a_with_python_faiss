# -----------------------------------------------------------------------
# RAG System Configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# -----------------------------------------------------------------------

# --- LLM Provider ---
# Which provider to use for the generation step: "anthropic", "openai", or "groq"
LLM_PROVIDER=groq

# API key for the selected provider. NEVER commit a real key.
# Get an Anthropic key at https://console.anthropic.com/
# Get an OpenAI key at https://platform.openai.com/
# Get a Groq key at https://console.groq.com/keys
LLM_API_KEY=your_api_key_here

# Model name for the selected provider.
# Anthropic examples: claude-sonnet-4-6, claude-haiku-4-5-20251001
# OpenAI examples: gpt-4o-mini, gpt-4o
# Groq examples: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# --- Chunking parameters ---
# Number of characters per chunk
CHUNK_SIZE=500
# Number of overlapping characters between consecutive chunks
CHUNK_OVERLAP=50

# --- Retrieval parameters ---
# Number of chunks to retrieve per query
TOP_K=3

# --- Storage ---
# Directory where the FAISS index + chunk map are persisted
INDEX_DIR=./index_store

# --- Embedding model ---
# Any sentence-transformers model name
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
